{
  "appId": "com.donkiepa.squaredcircle",
  "appName": "Squared Circle",
  "webDir": "dist",
  "android": {
    "buildOptions": {
      "keystorePath": "release.keystore",
      "keystoreAlias": "squared-circle"
    }
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f0f1a",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
